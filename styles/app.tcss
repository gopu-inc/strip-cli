    color: #00e5ff;
}

/* Primary accent — borders on hover/active */
App.theme-ocean VideoCard:hover,
App.theme-ocean PostCard:hover,
App.theme-ocean SoundCard:hover,
App.theme-ocean ThemeCard:hover,
App.theme-ocean LiveCard:hover,
App.theme-ocean UserResult:hover,
App.theme-ocean StoryBubble,
App.theme-ocean #viewer-box,
App.theme-ocean #player-bar,
App.theme-ocean #voice-bar {
    border: solid #4dabf7;
}

App.theme-ocean #feed-tabs Button.tab-active,
App.theme-ocean #cat-bar Button.cat-active,
App.theme-ocean #type-bar Button.type-active {
    color: #4dabf7;
    border-bottom: solid #4dabf7;
}

App.theme-ocean #theme-btns Button.theme-btn-active {
    background: #4dabf7;
    color: #000;
}

App.theme-ocean #msg-list MsgItem.mine {
    background: #021024;
    border-right: solid #4dabf7;
}

App.theme-ocean #msg-list MsgItem.theirs {
    background: #010b1a;
    border-left: solid #00e5ff;
}

App.theme-ocean #conv-list ConvItem.--highlight {
    background: #051530;
    border-left: solid #4dabf7;
}

App.theme-ocean ThemeCard.theme-selected,
App.theme-ocean PostCard.--highlight,
App.theme-ocean SoundCard.--highlight,
App.theme-ocean VideoCard.--highlight {
    border: solid #4dabf7;
    background: #051530;
}

App.theme-ocean #voice-bar {
    background: #001224;
    border-top: solid #4dabf7;
}

