/* ═══════════════════════════════════════════════════════════════════════════
   STRIP TUI — Feuille de style principale
   Thèmes: dark (défaut), cyber, ocean, sunset
   ═══════════════════════════════════════════════════════════════════════════ */

/* ─── Base ────────────────────────────────────────────────────────────────── */

App {
    background: #0a0a0f;
}

Screen {
    background: #0a0a0f;
    color: #e0e0e0;
    layers: base overlay;
}

Header {
    background: #13131f;
    color: #e94560;
    height: 1;
    text-style: bold;
}

Footer {
    background: #13131f;
    color: #555577;
    height: 1;
}

/* ─── Typographie globale ─────────────────────────────────────────────────── */

Label.title {
    text-style: bold;
    color: #e94560;
    text-align: center;
}

Label.subtitle {
    color: #888;
    text-align: center;
}

Label.section-title {
    text-style: bold;
    color: #4dabf7;
    padding: 0 1;
}

Label.muted {
    color: #555577;
}

Label.success {
    color: #51cf66;
}

Label.error {
    color: #ff6b6b;
}

Label.warning {
    color: #f59f00;
}

Label.online {
    color: #51cf66;
}

Label.verified {
    color: #4dabf7;
}

/* ─── Boutons ─────────────────────────────────────────────────────────────── */

Button {
    margin: 0 1;
    padding: 0 2;
    border: none;
    background: #1e1e2e;
    color: #e0e0e0;
    height: 3;
}

Button:hover {
    background: #2a2a3e;
}

Button:focus {
    border: solid #e94560;
}

Button.-primary {
    background: #e94560;
    color: #fff;
}

Button.-primary:hover {
    background: #c73652;
}

Button.-success {
    background: #51cf66;
    color: #000;
}

Button.-success:hover {
    background: #3eb554;
}

Button.-warning {
    background: #f59f00;
    color: #000;
}

Button.-error {
    background: #ff6b6b;
    color: #fff;
}

Button.nav-btn {
    background: #13131f;
    color: #555577;
    width: 1fr;
    height: 3;
    border: none;
    margin: 0;
}

Button.nav-btn:hover {
    background: #1e1e2e;
    color: #e0e0e0;
}

Button.nav-active {
    background: #1e1e2e;
    color: #e94560;
}

Button.action-btn {
    background: transparent;
    color: #888;
    min-width: 8;
    height: 1;
    padding: 0 1;
    margin: 0;
    border: none;
}

Button.action-btn:hover {
    color: #e94560;
}

Button.liked {
    color: #e94560;
}

/* ─── Inputs ──────────────────────────────────────────────────────────────── */

Input {
    background: #13131f;
    border: solid #2a2a3e;
    color: #e0e0e0;
    padding: 0 1;
}

Input:focus {
    border: solid #e94560;
    background: #16161f;
}

Input.-valid {
    border: solid #51cf66;
}

/* ─── Conteneurs ──────────────────────────────────────────────────────────── */

#nav-bar {
    height: 3;
    background: #0d0d18;
    border-top: solid #1e1e2e;
    dock: bottom;
    padding: 0;
}

.panel {
    background: #13131f;
    border: solid #1e1e2e;
    padding: 1;
}

.card {
    background: #13131f;
    border: solid #1e1e2e;
    padding: 1;
    margin: 0 0 1 0;
}

.card:hover {
    border: solid #e94560;
}

/* ─── ListView ────────────────────────────────────────────────────────────── */

ListView {
    background: transparent;
    border: none;
}

ListItem {
    background: #13131f;
    padding: 1;
    margin: 0 0 1 0;
    border: solid #1e1e2e;
}

ListItem:hover {
    background: #1a1a2a;
    border: solid #e94560;
}

ListItem.--highlight {
    background: #1e1e2e;
    border: solid #e94560;
}

/* ─── Switch ──────────────────────────────────────────────────────────────── */

Switch {
    background: #1e1e2e;
}

Switch.-on {
    background: #e94560;
}

/* ─── Rule ────────────────────────────────────────────────────────────────── */

Rule {
    color: #2a2a3e;
    margin: 1 0;
}

/* ─── LoadingIndicator ────────────────────────────────────────────────────── */

LoadingIndicator {
    color: #e94560;
}

/* ─── DataTable ───────────────────────────────────────────────────────────── */

DataTable {
    background: #13131f;
    border: solid #1e1e2e;
    color: #e0e0e0;
}

DataTable > .datatable--header {
    background: #1e1e2e;
    color: #e94560;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: #e94560;
    color: #fff;
}

/* ─── Tabs / TabbedContent ────────────────────────────────────────────────── */

Tabs {
    background: #0d0d18;
    border-bottom: solid #1e1e2e;
}

Tab {
    background: transparent;
    color: #555577;
    padding: 1 2;
}

Tab.-active {
    color: #e94560;
    border-bottom: solid #e94560;
    background: #13131f;
}

Tab:hover {
    color: #e0e0e0;
}

TabbedContent {
    background: #0a0a0f;
}

TabPane {
    background: #0a0a0f;
    padding: 1;
}

/* ─── ProgressBar ─────────────────────────────────────────────────────────── */

ProgressBar {
    color: #e94560;
}

ProgressBar > .bar--bar {
    color: #e94560;
}

/* ─── Markdown ────────────────────────────────────────────────────────────── */

Markdown {
    background: transparent;
    color: #e0e0e0;
}

/* Textual CSS does not support descendant/child selectors — heading/code
   colours are handled per-theme via MarkdownH1 / MarkdownFence widgets */
MarkdownH1 {
    color: #e94560;
}
MarkdownH2 {
    color: #e94560;
}
MarkdownH3 {
    color: #e94560;
}
MarkdownFence {
    background: #1e1e2e;
}

/* ═══════════════════════════════════════════════════════════════════════════
   THÈME: CYBER (matrix green)
   ═══════════════════════════════════════════════════════════════════════════ */

App.theme-cyber {
    background: #000d00;
}

App.theme-cyber Screen {
    background: #000d00;
    color: #b0ffb0;
}

App.theme-cyber Header {
    background: #001500;
    color: #00ff41;
}

App.theme-cyber Footer {
    background: #001500;
    color: #005500;
}

App.theme-cyber Label.title {
    color: #00ff41;
}

App.theme-cyber Label.section-title {
    color: #00cc33;
}

App.theme-cyber Button {
    background: #001500;
    color: #b0ffb0;
}

App.theme-cyber Button.-primary {
    background: #00ff41;
    color: #000;
}

App.theme-cyber Button.nav-btn {
    background: #001500;
    color: #005500;
}

App.theme-cyber Button.nav-active {
    color: #00ff41;
}

App.theme-cyber Button.action-btn:hover {
    color: #00ff41;
}

App.theme-cyber Input {
    background: #001500;
    border: solid #003300;
    color: #b0ffb0;
}

App.theme-cyber Input:focus {
    border: solid #00ff41;
}

App.theme-cyber ListItem {
    background: #001500;
    border: solid #003300;
}

App.theme-cyber ListItem:hover {
    background: #002200;
    border: solid #00ff41;
}

App.theme-cyber .panel {
    background: #001500;
    border: solid #003300;
}

App.theme-cyber .card {
    background: #001500;
    border: solid #003300;
}

App.theme-cyber .card:hover {
    border: solid #00ff41;
}

App.theme-cyber Tab.-active {
    color: #00ff41;
    border-bottom: solid #00ff41;
    background: #001500;
}

App.theme-cyber #nav-bar {
    background: #000d00;
    border-top: solid #003300;
}

App.theme-cyber DataTable > .datatable--header {
    background: #003300;
    color: #00ff41;
}

App.theme-cyber DataTable > .datatable--cursor {
    background: #00ff41;
    color: #000;
}

App.theme-cyber Switch.-on {
    background: #00ff41;
}

/* ═══════════════════════════════════════════════════════════════════════════
   THÈME: OCEAN (deep blue)
   ═══════════════════════════════════════════════════════════════════════════ */

