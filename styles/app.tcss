/* ═══════════════════════════════════════════════════════════════════════════
   PER-SCREEN THEME OVERRIDES
   Covers every hardcoded hex in screen CSS strings so themes apply globally.
   Panel bg  = #13131f  │  Dark bg  = #0d0d18 / #0a0a0f
   Border    = #1e1e2e  │  Hover bg = #16161f
   Primary   = #e94560  │  Secondary = #4dabf7
   ═══════════════════════════════════════════════════════════════════════════ */

/* ─── CYBER per-screen ─────────────────────────────────────────────────────── */

/* Panel / header backgrounds */
App.theme-cyber #dash-header,
App.theme-cyber StatCard,
App.theme-cyber #add-story-btn,
App.theme-cyber #feed-header,
App.theme-cyber VideoCard,
App.theme-cyber #feed-bottom,
App.theme-cyber #chat-header,
App.theme-cyber #conversation-header,
App.theme-cyber #input-area,
App.theme-cyber #af-header,
App.theme-cyber PostCard,
App.theme-cyber #viewer-header,
App.theme-cyber #viewer-actions,
App.theme-cyber #write-header,
App.theme-cyber #write-actions,
App.theme-cyber #af-bottom,
App.theme-cyber #exp-header,
App.theme-cyber UserResult,
App.theme-cyber #exp-bottom,
App.theme-cyber #sounds-header,
App.theme-cyber SoundCard,
App.theme-cyber #sounds-bottom,
App.theme-cyber #stories-header,
App.theme-cyber #viewer-box,
App.theme-cyber #stories-bottom,
App.theme-cyber #settings-header,
App.theme-cyber ThemeCard,
App.theme-cyber #account-section,
App.theme-cyber #settings-bottom,
App.theme-cyber #live-header,
App.theme-cyber LiveCard,
App.theme-cyber #my-live-panel,
App.theme-cyber #notif-header,
App.theme-cyber #notif-bottom,
App.theme-cyber NotifItem,
App.theme-cyber #profile-header,
App.theme-cyber #profile-bottom,
App.theme-cyber .content-card,
App.theme-cyber #stream-info-box,
App.theme-cyber #live-bottom {
    background: #001500;
}

/* Dark panel backgrounds */
App.theme-cyber #sidebar,
App.theme-cyber #chat-panel,
App.theme-cyber #feed-panel,
App.theme-cyber #dash-nav,
App.theme-cyber #feed-tabs,
App.theme-cyber #cat-bar,
App.theme-cyber #search-row,
App.theme-cyber #type-bar,
App.theme-cyber #bubbles-panel,
App.theme-cyber #trending-panel,
App.theme-cyber #player-bar,
App.theme-cyber #hint-bar,
App.theme-cyber #voice-bar,
App.theme-cyber #story-viewer,
App.theme-cyber #lives-panel,
App.theme-cyber #stats-row,
App.theme-cyber #profile-tabs,
App.theme-cyber #filter-bar {
    background: #000d00;
}

/* Border/secondary bg widgets */
App.theme-cyber StoryBubble,
App.theme-cyber .story-circle,
App.theme-cyber #player-controls Button,
App.theme-cyber MarkdownFence {
    background: #003300;
}

/* Hover states */
App.theme-cyber VideoCard:hover,
App.theme-cyber PostCard:hover,
App.theme-cyber SoundCard:hover,
App.theme-cyber ThemeCard:hover,
App.theme-cyber LiveCard:hover,
App.theme-cyber UserResult:hover {
    background: #002200;
}

/* Primary accent — text colours */
App.theme-cyber #feed-title,
App.theme-cyber #chat-title,
App.theme-cyber #af-title,
App.theme-cyber #exp-title,
App.theme-cyber #sounds-title,
App.theme-cyber #stories-title,
App.theme-cyber #settings-title,
App.theme-cyber #live-title,
App.theme-cyber #notif-title,
App.theme-cyber #username-line,
App.theme-cyber #avatar-icon,
App.theme-cyber .stat-number,
App.theme-cyber #my-live-title,
App.theme-cyber #viewer-author,
App.theme-cyber #viewer-user,
App.theme-cyber #conv-username,
App.theme-cyber #voice-status,
App.theme-cyber MarkdownH1,
App.theme-cyber MarkdownH2,
App.theme-cyber MarkdownH3 {
    color: #00ff41;
}

/* Secondary accent — text colours */
App.theme-cyber #contacts-label,
App.theme-cyber #activity-title,
App.theme-cyber #trending-title,
App.theme-cyber #badge-line,
App.theme-cyber .section-header {
    color: #00cc33;
}

/* Primary accent — borders on hover/active */
App.theme-cyber VideoCard:hover,
App.theme-cyber PostCard:hover,
App.theme-cyber SoundCard:hover,
App.theme-cyber ThemeCard:hover,
App.theme-cyber LiveCard:hover,
App.theme-cyber UserResult:hover,
App.theme-cyber StoryBubble,
App.theme-cyber #viewer-box,
App.theme-cyber #player-bar,
App.theme-cyber #voice-bar {
    border: solid #00ff41;
}

App.theme-cyber #feed-tabs Button.tab-active,
App.theme-cyber #cat-bar Button.cat-active,
App.theme-cyber #type-bar Button.type-active {
    color: #00ff41;
    border-bottom: solid #00ff41;
}

App.theme-cyber #theme-btns Button.theme-btn-active {
    background: #00ff41;
    color: #000;
}

App.theme-cyber #msg-list MsgItem.mine {
    background: #001500;
    border-right: solid #00ff41;
}

App.theme-cyber #msg-list MsgItem.theirs {
    background: #000d00;
    border-left: solid #00cc33;
}

App.theme-cyber #conv-list ConvItem.--highlight {
    background: #002200;
    border-left: solid #00ff41;
}

App.theme-cyber ThemeCard.theme-selected,
App.theme-cyber PostCard.--highlight,
App.theme-cyber SoundCard.--highlight,
App.theme-cyber VideoCard.--highlight {
    border: solid #00ff41;
    background: #002200;
}

App.theme-cyber #voice-bar {
    background: #001500;
    border-top: solid #00ff41;
}

